<?xml version="1.0" encoding="UTF-8"?>
<!--
  MotionCraft Pro - CEP Extension Manifest
  Registers a single dockable panel that runs inside After Effects.
  Bumping ExtensionBundleVersion busts the host's extension cache.
-->
<ExtensionManifest Version="7.0"
    ExtensionBundleId="com.motioncraft.pro"
    ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="MotionCraft Pro"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <ExtensionList>
    <Extension Id="com.motioncraft.pro.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <!-- Support the broad range of AE versions that ship CEP 8+ (AE CC 2018 -> 2025+) -->
    <HostList>
      <Host Name="AEFT" Version="[15.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="8.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.motioncraft.pro.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/MotionCraft.jsx</ScriptPath>
          <CEFCommandLine>
            <!-- Allow local file access for lazy-loaded previews & node integration -->
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>MotionCraft Pro</Menu>
          <Geometry>
            <Size>
              <Height>640</Height>
              <Width>380</Width>
            </Size>
            <MinSize>
              <Height>420</Height>
              <Width>300</Width>
            </MinSize>
            <MaxSize>
              <Height>2400</Height>
              <Width>1200</Width>
            </MaxSize>
          </Geometry>
          <Icons>
            <Icon Type="Normal">./icons/panel-icon.png</Icon>
          </Icons>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
